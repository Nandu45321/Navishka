#: import gch kivy.utils.get_color_from_hex

<SmallCard>:
    id: customcard
    orientation: 'vertical'
    size_hint_y: None
    height: 384/2.65
    focus_behavior: True
    ripple_behavior: True
    style: "outlined"
    focus_color: "purple"
    elevation: 6
    radius: 10
    FitImage:
        source: root.imagepath # "arch-linux-logo-png-clipart-1507156103.png"
        radius: 10,10,0,0
        allow_stretch: True
        halign: 'center'
    MDSeparator:

    MDLabel:
        text: root.shape
        halign: 'center'
        size_hint: 1, 0.2
    MDLabel:
        text: root.inputs
        text_font_size: 7
        halign: 'center'
        size_hint: 1, 0.2
    MDLabel:
        text: root.outputs
        halign: 'center'
        size_hint: 1, 0.2

<TwoDNavigationItem>:
    id: TwoDNavigationItem
    MDNavigationItemIcon:
        icon: root.icon
    MDNavigationItemLabel:
        text: root.text


<TwoDScreen>:
    name: '2D'
    MDLabel:
        text: '2D'
        halign: 'center'


<ThreeDScreen>:
    name: '3D'
    MDLabel:
        text: '3D'
        halign: 'center'

<MainScreenView>:
    name: "main screen"
    MDBoxLayout:
        orientation: 'vertical'
        md_bg_color: self.theme_cls.backgroundColor
        MDScreenManager:
            id: entry_screen_manager

            TwoDScreen:

            ThreeDScreen:

        MDNavigationBar:
            id: NavBar
            # I do not know how the below three lines work. Don't touch them.
            on_switch_tabs:
                root.on_switch_tabs(bar=NavBar, item='TwoDNavigationItem', item_icon='square', item_text='2D' if entry_screen_manager.current == '3D' else '3D')
                entry_screen_manager.transition.direction = 'left' if entry_screen_manager.current == '3D' else 'right'
            TwoDNavigationItem
                icon: 'square-outline'
                text: '2D'
                active: True

            TwoDNavigationItem
                icon: 'cube'
                text: '3D'



    MDNavigationDrawer:
        id: navigation_drawer
        opening_time: 0.5
        closing_time: 0.4
        enable_swiping: True
        type: "standard"
        status: "opening_with_swipe"
        BoxLayout:
            orientation: 'vertical'
            MDLabel:
                text: 'Under Construction'
                halign: 'center'
#: import gch kivy.utils.get_color_from_hex

<SmallCard>:
    id: customcard
    orientation: 'vertical'
    size_hint_y: None
    height: 384/2.65
    focus_behavior: True
    ripple_behavior: True
    style: "outlined"
    focus_color: "purple"
    elevation: 6
    radius: 10
    FitImage:
        source: root.imagepath # "arch-linux-logo-png-clipart-1507156103.png"
        radius: 10,10,0,0
        allow_stretch: True
        halign: 'center'
    MDSeparator:

    MDLabel:
        text: root.shape
        halign: 'center'
        size_hint: 1, 0.2
    MDLabel:
        text: root.inputs
        text_font_size: 7
        halign: 'center'
        size_hint: 1, 0.2
    MDLabel:
        text: root.outputs
        halign: 'center'
        size_hint: 1, 0.2


<MainScreenView>:
    name: "main screen"
    MDNavigationLayout:
        MDScreenManager:
            MDScreen:
                MDBoxLayout:
                    orientation: 'vertical'
                    MDTopAppBar:
                        title: "Navishka"
                        elevation: 10
                        left_action_items: [["menu", lambda x : navigation_drawer.set_state("toggle")]]
                        #left_action_items: [["menu", lambda x : app.root.current]]
                        #right_action_items: [["history")]]
                    MDNavigationBar:
                        text_color_active: gch("#673AB7")
                        pos_hint: {'top': 0.5}
                        MDNavigationItem:
                            text: "2D"
                            name: "2D screen"
                            icon: "square-outline"
                            Button:
                                pos_hint:{'top' :1}
                            ScrollView:
                                do_scroll_x: False
                                scroll_type: ['bars', 'content']
                                smooth_scroll_end: '10px'
                                BoxLayout:
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: '3px'
                                    spacing: '3px'
                                    BoxLayout:
                                        spacing: '3px'
                                        orientation: 'vertical'
                                        size_hint_y: None
                                        height: self.minimum_height
                                        pos_hint: {"top": 1}
                                        Button:
                                            on_release: print("Button 1")


                                    BoxLayout:
                                        spacing: '3px'
                                        orientation: 'vertical'
                                        size_hint_y: None
                                        height: self.minimum_height
                                        pos_hint: {"top": 1}
                                        Button:
                                            on_release: print("Button 2")


                        MDNavigationItem:
                            text: "3D"
                            name: "3D screen"
                            icon: "cube"

                            ScrollView:
                                do_scroll_x: False
                                scroll_type: ['bars', 'content']
                                smooth_scroll_end: '10px'
                                BoxLayout:
                                    size_hint_y: None
                                    height: self.minimum_height
                                    padding: '3px'
                                    spacing: '3px'
                                    BoxLayout:
                                        spacing: '3px'
                                        orientation: 'vertical'
                                        size_hint_y: None
                                        height: self.minimum_height




                                    BoxLayout:
                                        spacing: '3px'
                                        orientation: 'vertical'
                                        size_hint_y: None
                                        height: self.minimum_height



        MDNavigationDrawer:
            id: navigation_drawer
            opening_time: 0.5
            closing_time: 0.4
            enable_swiping: True
            #type: "standard"
            #status: "opening_with_swipe"
            BoxLayout:
                orientation: 'vertical'
                padding: dp(5)